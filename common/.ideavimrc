" ============================================================================
" .ideavimrc — Matched to nvim config
" ============================================================================

" Disable auto commenting
autocmd BufEnter * set formatoptions-=cro

" --- Leader ---
nnoremap <SPACE> <Nop>
let mapleader = " "
let maplocalleader = " "

" --- Settings (match nvim options.lua) ---
set number
set relativenumber
set ignorecase
set smartcase
set incsearch
set scrolloff=8
set sidescrolloff=8
set clipboard+=unnamedplus
set ideastrictmode

" --- Plugins ---
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
set NERDTree
set argtextobj
set highlightedyank
set which-key
set mini-ai

" Flash (install vim-flash plugin from JetBrains marketplace)
nmap s <action>(flash.search)
nmap S <action>(flash.treesitter)
omap r <action>(flash.remote)

" --- Surround Hack (gs prefix to match mini.surround) ---
nmap gs ys
xmap gs S
nmap gsd ds
nmap gsr cs

" --- Better Search ---
nnoremap n nzzzv
nnoremap N Nzzzv

" --- Centered Scrolling ---
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" --- Better Pasting ---
vnoremap <silent> p "_dP

" --- Moving Lines ---
inoremap <Up> <Esc>:m .-2<CR>==gi
nnoremap <Up> :m .-2<CR>==
vnoremap <Up> :m '<-2<CR>gv=gv
inoremap <Down> <Esc>:m .+1<CR>==gi
nnoremap <Down> :m .+1<CR>==
vnoremap <Down> :m '>+1<CR>gv=gv

" --- Saving ---
nmap <leader>w :w<CR>
nmap <leader>W :wa<CR>

" ============================================================================
" PROJECT NAVIGATION
" ============================================================================

" Search (<leader>ps* namespace — no conflicts)
nmap <leader>pf <action>(GotoFile)
nmap <leader>pse <action>(SearchEverywhere)
nmap <leader>pss <action>(FindInPath)
nmap <leader>psw <action>(FindWordAtCaret)
nmap <leader>psd <action>(ActivateProblemsViewToolWindow)
nmap <leader>psr <action>(FindInPath)

" Project View & Buffers
nmap <leader>pv <action>(ActivateProjectToolWindow)
nmap <leader>pb <action>(Switcher)
nmap <leader>pr <action>(RecentFiles)
nmap <leader>pg <action>(GotoFile)

" Buffer search
nmap <leader>/ <action>(Find)

" ============================================================================
" CODE NAVIGATION (LSP equivalents)
" ============================================================================

nmap gd <action>(GotoDeclaration)
nmap gD <action>(GotoTypeDeclaration)
nmap gr <action>(ShowUsages)
nmap gI <action>(GotoImplementation)
nmap K <action>(QuickJavaDoc)

" Symbols
nmap <leader>cs <action>(FileStructurePopup)
nmap <leader>cS <action>(GotoSymbol)

" ============================================================================
" CODE ACTIONS
" ============================================================================

nmap <leader>ca <action>(ShowIntentionActions)
nmap <leader>cr <action>(RenameElement)
nmap <leader>cf <action>(ReformatCode)
nmap <leader>cR <action>(RenameFile)

" ============================================================================
" SPLITS & WINDOW NAVIGATION
" ============================================================================

" Navigate between splits
nmap <C-h> <C-w>h
nmap <C-j> <C-w>j
nmap <C-k> <C-w>k
nmap <C-l> <C-w>l

" Create splits (match nvim <leader>n* directional splits)
nmap <leader>nh <action>(SplitVertically)<action>(MoveEditorToOppositeTabGroup)
nmap <leader>nj <action>(SplitHorizontally)
nmap <leader>nk <action>(SplitHorizontally)<action>(MoveEditorToOppositeTabGroup)
nmap <leader>nl <action>(SplitVertically)
nmap <leader>ns :clo<CR>

" ============================================================================
" DEBUGGING
" ============================================================================

nmap <leader>db <action>(ToggleLineBreakpoint)
nmap <leader>dB <action>(EditBreakpoint)
nmap <leader>dc <action>(Resume)
nmap <leader>di <action>(StepInto)
nmap <leader>do <action>(StepOver)
nmap <leader>dO <action>(StepOut)
nmap <leader>dx <action>(Stop)
nmap <leader>dd <action>(Debug)
nmap <leader>dr <action>(EvaluateExpression)

" ============================================================================
" GITHUB COPILOT
" ============================================================================

imap <C-l> <action>(copilot.applyInlays)
imap <C-s> <action>(copilot.applyInlaysNextWord)

" ============================================================================
" MISC
" ============================================================================

" Popup menu navigation
nmap <C-n> <action>(PopupMenu-selectNext)
nmap <C-p> <action>(PopupMenu-selectPrevious)

" Reload config
nmap <leader>zo :so ~/.ideavimrc<CR>
